# Copy to .env for local overrides.
RFP_RAG_DATA_DIR=data
RFP_RAG_INDEX_DIR=data/index
RFP_RAG_LOG_LEVEL=INFO
RFP_RAG_DEFAULT_PROMPT_MODE=retrieve_only
RFP_RAG_SUPPORTED_EXTENSIONS=.docx,.xlsx
RFP_RAG_VECTOR_COLLECTION=rfp_answers
RFP_RAG_DEFAULT_TOP_K=5
RFP_RAG_MAX_CONTEXT_CHARS=12000
RFP_RAG_KEYWORD_WEIGHT=0.35
RFP_RAG_SEMANTIC_WEIGHT=0.65
RFP_RAG_REQUIRE_APPROVED_ANSWERS=false
RFP_RAG_WORD_CHUNK_MAX_CHARS=4000
RFP_RAG_EXCEL_ROW_GROUP_SIZE=1
RFP_RAG_PRESERVE_TABLES=true
RFP_RAG_DETECT_QA_BLOCKS=true
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5
OPENAI_REASONING_MODEL=gpt-5
OPENAI_RESPONSES_DEBUG=false
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBED_DEPLOYMENT=
CHROMA_ENDPOINT=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
